[Unit]
Description=Bybit Quant Bot V8.0 (Auto Trader)
After=network.target postgresql.service

[Service]
Type=simple
User=bybitbot
Group=bybitbot
WorkingDirectory=/opt/Bot-Auto-Screening-Bybit
ExecStart=/opt/Bot-Auto-Screening-Bybit/venv/bin/python auto_trades.py
Restart=always
RestartSec=5
Environment="BOT_ENV=production"
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/Bot-Auto-Screening-Bybit

[Install]
WantedBy=multi-user.target
